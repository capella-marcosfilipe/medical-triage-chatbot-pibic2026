# Variáveis de ambiente lidas pelo docker-compose.yml na raiz do projeto.
# Copie este arquivo para ".env" (mesma pasta) e preencha os valores reais.
# O `docker compose` carrega ".env" automaticamente quando ele está ao lado
# do docker-compose.yml — não é preciso passar --env-file.
#
# Isso é separado dos .env de cada serviço (chat-rag-microservice/.env,
# chatbot-backend/.env), que só valem para execução local fora do Docker.

# Chave de API da NVIDIA (gratuita em https://build.nvidia.com), usada pelo
# chat-rag-microservice e pelo worker de API para chamadas ao Nemotron.
# Se ausente ou vazia, o container sobe normalmente mas toda chamada de chat
# falha em runtime com "MAX_RETRIES_EXCEEDED: Connection error" (o SDK da
# OpenAI rejeita o header "Authorization: Bearer " vazio antes de conectar).
NVIDIA_API_KEY=your_nvidia_api_key_here
